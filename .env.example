# Flask application
FLASK_ENV=development           # development | testing | production
SECRET_KEY=change-me-to-a-random-secret

# Database
# SQLite (default for development):
# DATABASE_URL=sqlite:////absolute/path/to/trackwise.db
#
# PostgreSQL (dedicated server - production):
# DATABASE_URL=postgresql+psycopg://trackwise:trackwise@localhost:5432/trackwise
#
# Neon (serverless Postgres - production):
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+psycopg://trackwise:trackwise@localhost:5432/trackwise
