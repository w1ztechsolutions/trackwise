# Flask application
FLASK_ENV=development           # development | testing | production
SECRET_KEY=change-me-to-a-random-secret

# Database
# SQLite (default for development):
# DATABASE_URL=sqlite:////absolute/path/to/trackwise.db
#
# PostgreSQL (dedicated server - production):
# DATABASE_URL=postgresql+psycopg://trackwise:trackwise@localhost:5432/trackwise
#
# Neon (serverless Postgres - recommended for Vercel):
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+psycopg://trackwise:trackwise@localhost:5432/trackwise

# Redis (for Celery - optional, defaults to disabled on Vercel)
# REDIS_URL=redis://default:password@host.upstash.io:port

# Stripe (for subscriptions)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Celery configuration (disabled by default for serverless)
CELERY_DISABLED=true
WEASYPRINT_CACHEDIR=/tmp/weasyprint-cache